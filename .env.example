# Supabase — copier ce fichier en .env.local et remplir les valeurs
# Dashboard Supabase > Settings > API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL canonique du site (utilisée par metadataBase, sitemap, robots)
# En prod : https://<ton-domaine>
# En dev :  laisser vide (Next utilisera localhost:3000)
NEXT_PUBLIC_SITE_URL=
